{
  "active": {
    "version": "CURRENT",
    "layoutFlex": {
      "flow": "COLUMN",
      "gap": 8,
      "layout": {
        "children": [
          {
            "layoutFlex": {
              "gap": 8,
              "layout": {
                "children": [
                  {
                    "id": "prev",
                    "button": {
                      "text": "< Prev",
                      "onClick": [
                        {
                          "device": {
                            "changeWidgetRef": {
                              "behavior": "PREVIOUS",
                              "path": "F:host/uscr/",
                              "targetId": "page"
                            }
                          }
                        }
                      ]
                    }
                  },
                  {
                    "id": "chrome_gap",
                    "rect": {
                      "flexGrow": 1
                    },
                    "spacer": {}
                  },
                  {
                    "id": "next",
                    "button": {
                      "text": "Next >",
                      "onClick": [
                        {
                          "device": {
                            "changeWidgetRef": {
                              "behavior": "NEXT",
                              "path": "F:host/uscr/",
                              "targetId": "page"
                            }
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          },
          {
            "id": "page",
            "rect": {
              "flexGrow": 1
            },
            "widgetRef": {
              "path": "F:host/uscr/trackpad.pb"
            }
          }
        ]
      }
    }
  }
}
